{
    "id": "org.kde.spacebar",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.11",
    "sdk": "org.kde.Sdk",
    "command": "spacebar",
    "tags": [
        "nightly"
    ],
    "desktop-file-name-suffix": " (Nightly)",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=x11",
        "--socket=wayland",
        "--device=dri",
        "--talk-name=org.freedesktop.Notifications",
        "--own-name=org.kde.Spacebar",
        "--system-talk-name=org.freedesktop.ModemManager1"
    ],
    "separate-locales": false,
    "cleanup": [
        "/include/",
        "/lib/cmake/",
        "/lib/pkgconfig",
        "/bin/protoc-*",
        "/share/man/",
        "/lib/*.a"
    ],
    "modules": [
        {
            "name": "kpeople",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "git",
                    "url": "https://invent.kde.org/frameworks/kpeople",
                    "tag": "v6.27.0"
                }
            ],
            "cleanup": [
                "/bin/"
            ]
        },
        {
            "name": "modemmanager",
            "buildsystem": "meson",
            "config-opts": [
                "-Dudev=false",
                "-Dmbim=false",
                "-Dqmi=false",
                "-Dudevdir=/app/",
                "-Dbash_completion=false",
                "-Dsystemd_suspend_resume=false",
                "-Dpowerd_suspend_resume=false",
                "-Dsystemd_journal=false",
                "-Dsystemdsystemunitdir=no",
                "-Dpolkit=no",
                "-Dqrtr=false"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://gitlab.freedesktop.org/mobile-broadband/ModemManager/-/archive/1.24.2/ModemManager-1.24.2.zip",
                    "sha256": "94585740d456232d38f88c3d87bcdec3b93d2390fbf2c9fde2dcf67f113dc145",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 7306,
                        "stable-only": true,
                        "url-template": "https://gitlab.freedesktop.org/mobile-broadband/ModemManager/-/archive/$version/ModemManager-$version.zip"
                    }
                }
            ],
            "cleanup": [
                "/bin/",
                "/lib/ModemManager"
            ]
        },
        {
            "name": "modemmanager-qt",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "git",
                    "url": "https://invent.kde.org/frameworks/modemmanager-qt",
                    "tag": "v6.26.0"
                }
            ]
        },
        {
            "name": "abseil-cpp",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBUILD_SHARED_LIBS=ON",
                "-DABSL_PROPAGATE_CXX_STD=ON",
                "-DCMAKE_POSITION_INDEPENDENT_CODE=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/abseil/abseil-cpp/archive/refs/tags/20260526.0.tar.gz",
                    "sha256": "6e1aee535473414164bf83e4ebc40240dec71a4701f8a642d906e95bea1aea0c",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 115295,
                        "stable-only": true,
                        "url-template": "https://github.com/abseil/abseil-cpp/archive/refs/tags/$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "protobuf",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-Dprotobuf_BUILD_TESTS=OFF",
                "-Dprotobuf_ABSL_PROVIDER=package",
                "-DBUILD_SHARED_LIBS=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/protocolbuffers/protobuf/archive/refs/tags/v35.1.tar.gz",
                    "sha256": "22775f9376938295efa2d59a59bde4cd075a42df5a9b4d27aa9b99fa6a413bd2",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 3715,
                        "stable-only": true,
                        "url-template": "https://github.com/protocolbuffers/protobuf/archive/refs/tags/v$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "libphonenumber",
            "buildsystem": "cmake-ninja",
            "subdir": "cpp",
            "config-opts": [
                "-DUSE_BOOST=OFF",
                "-DBUILD_TESTING=OFF",
                "-DREGENERATE_METADATA=OFF",
                "-DBUILD_STATIC_LIB=OFF",
                "-DBUILD_SHARED_LIBS=ON",
                "-DUSE_PROTOBUF_LITE=ON",
                "-DBUILD_GEOCODER=OFF",
                "-DFETCHCONTENT_FULLY_DISCONNECTED=ON",
                "-DCMAKE_POSITION_INDEPENDENT_CODE=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/google/libphonenumber/archive/refs/tags/v9.0.33.tar.gz",
                    "sha256": "649e13846a7c49ca91ddfbf649e8feeafe7b04b590de4ce64cedfbf28d37b2ee",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 89344,
                        "stable-only": true,
                        "url-template": "https://github.com/google/libphonenumber/archive/refs/tags/v$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "c-ares",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/c-ares/c-ares/releases/download/v1.34.6/c-ares-1.34.6.tar.gz",
                    "sha256": "912dd7cc3b3e8a79c52fd7fb9c0f4ecf0aaa73e45efda880266a2d6e26b84ef5",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 5840,
                        "stable-only": true,
                        "url-template": "https://github.com/c-ares/c-ares/releases/download/v$version/c-ares-$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "futuresql",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DQT_MAJOR_VERSION=6"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/futuresql/futuresql-0.1.1.tar.xz",
                    "sha256": "e44ed8d5a9618b3ca7ba2983ed9c5f7572e6e0a5b199f94868834b71ccbebd43"
                }
            ]
        },
        {
            "name": "spacebar",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "dir",
                    "path": ".",
                    "skip": [
                        ".git"
                    ]
                }
            ]
        }
    ]
}
